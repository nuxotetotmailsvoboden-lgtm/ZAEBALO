    <!-- ===== TOAST ===== -->
    <div id="toast" style="position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:rgba(10,10,15,0.92);backdrop-filter:blur(16px);border:1px solid rgba(168,85,247,0.15);border-radius:16px;padding:14px 28px;color:#f0f0ff;font-size:0.95rem;z-index:9999;box-shadow:0 20px 60px rgba(0,0,0,0.6);display:none;align-items:center;gap:12px;max-width:90%;text-align:center;transition:all 0.3s ease;"></div>

    <script>
        // ============================================================
        //  NOVA — Telegram Mini App (Pure JS)
        //  Full constructor, navigation, Telegram SDK simulation
        // ============================================================

        (function() {
            'use strict';

            // ---------- STATE ----------
            const state = {
                page: 'home',
                step: 0,
                projectType: 'Telegram Bot',
                functions: [],
                design: 'Light',
                baseCost: 40000,
                funcCosts: {
                    'Авторизация': 8000,
                    'Оплата': 12000,
                    'Админка': 15000,
                    'CRM': 15000,
                    'Рассылка': 8000,
                    'Уведомления': 6000,
                    'AI OpenAI': 18000,
                    'База данных': 12000,
                    'Личный кабинет': 10000,
                    'Реферальная система': 12000,
                    'Подписки': 14000,
                    'API Интеграции': 10000,
                },
                designCosts: {
                    'Light': 0,
                    'Dark': 5000,
                    'Premium': 15000,
                    'Corporate': 8000,
                    'Custom': 20000,
                },
                user: {
                    name: 'Алексей',
                    username: '@alex_dev',
                    id: '123456789',
                    registered: '2026-07-22',
                    requests: 3,
                }
            };

            // ---------- DOM REFS ----------
            const $ = (s) => document.querySelector(s);
            const $$ = (s) => document.querySelectorAll(s);

            const pages = {
                home: $('#page-home'),
                constructor: $('#page-constructor'),
                portfolio: $('#page-portfolio'),
                profile: $('#page-profile'),
            };
            const navItems = $$('.nav-item');
            const toastEl = $('#toast');

            // ---------- NAVIGATION ----------
            function showPage(name) {
                Object.keys(pages).forEach(k => pages[k].style.display = (k === name) ? 'block' : 'none');
                state.page = name;
                navItems.forEach(el => {
                    el.classList.toggle('active', el.dataset.page === name);
                });
                // Telegram SDK simulation: expand
                if (window.Telegram?.WebApp) {
                    try { window.Telegram.WebApp.expand(); } catch (e) {}
                }
                // scroll to top
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            // ---------- TOAST ----------
            let toastTimer = null;

            function showToast(msg, duration = 2800) {
                toastEl.textContent = msg;
                toastEl.style.display = 'flex';
                clearTimeout(toastTimer);
                toastTimer = setTimeout(() => {
                    toastEl.style.display = 'none';
                }, duration);
            }

            // ---------- NAV ITEMS ----------
            navItems.forEach(el => {
                el.addEventListener('click', () => {
                    const page = el.dataset.page;
                    if (page === 'constructor') {
                        renderStep(0);
                    }
                    showPage(page);
                });
            });

            // ---------- PROFILE BUTTON ----------
            $('#profileBtn').addEventListener('click', () => {
                showPage('profile');
                updateProfile();
            });
            $('#backFromProfile').addEventListener('click', () => showPage('home'));
            $('#backFromPortfolio').addEventListener('click', () => showPage('home'));
            $('#backHomeBtn').addEventListener('click', () => showPage('home'));

            // ---------- CTA / START ----------
            $('#startBtn').addEventListener('click', () => {
                showPage('constructor');
                renderStep(0);
            });
            $('#ctaBtn').addEventListener('click', () => {
                showPage('constructor');
                renderStep(0);
            });
            $('#demoBtn').addEventListener('click', () => {
                showToast('🎥 Демо-версия откроется в новом окне');
            });

            // ---------- CONSTRUCTOR: STEP RENDER ----------
            function renderStep(step) {
                state.step = step;
                // dots
                const dots = $$('.step-dot');
                dots.forEach((d, i) => {
                    d.classList.toggle('active', i === step);
                    d.classList.toggle('done', i < step);
                });
                // panels
                $$('.step-panel').forEach((p, i) => {
                    p.style.display = (i === step) ? 'block' : 'none';
                });
                // update step content
                if (step === 3) updateCost();
                // expand
                if (window.Telegram?.WebApp) {
                    try { window.Telegram.WebApp.expand(); } catch (e) {}
                }
            }

            // ---------- CONSTRUCTOR: STEP NAV ----------
            document.addEventListener('click', (e) => {
                const target = e.target.closest('.step-next');
                if (target) {
                    const next = state.step + 1;
                    if (next <= 3) renderStep(next);
                    return;
                }
                const prev = e.target.closest('.step-prev');
                if (prev) {
                    const prevStep = state.step - 1;
                    if (prevStep >= 0) renderStep(prevStep);
                    return;
                }
            });

            // ---------- CONSTRUCTOR: TYPE SELECTION ----------
            document.querySelectorAll('#typeOptions .option-chip').forEach(el => {
                el.addEventListener('click', function() {
                    document.querySelectorAll('#typeOptions .option-chip').forEach(c => c.classList.remove(
                    'selected'));
                    this.classList.add('selected');
                    state.projectType = this.dataset.type;
                });
            });

            // ---------- CONSTRUCTOR: FUNCTIONS ----------
            document.querySelectorAll('#funcOptions .option-chip').forEach(el => {
                el.addEventListener('click', function() {
                    this.classList.toggle('selected');
                    const func = this.dataset.func;
                    if (this.classList.contains('selected')) {
                        if (!state.functions.includes(func)) state.functions.push(func);
                    } else {
                        state.functions = state.functions.filter(f => f !== func);
                    }
                    // update cost if on step 3
                    if (state.step === 3) updateCost();
                });
            });

            // ---------- CONSTRUCTOR: DESIGN ----------
            document.querySelectorAll('#designOptions .option-chip').forEach(el => {
                el.addEventListener('click', function() {
                    document.querySelectorAll('#designOptions .option-chip').forEach(c => c.classList.remove(
                    'selected'));
                    this.classList.add('selected');
                    state.design = this.dataset.design;
                    if (state.step === 3) updateCost();
                });
            });

            // ---------- COST CALC ----------
            function updateCost() {
                const funcTotal = state.functions.reduce((sum, f) => sum + (state.funcCosts[f] || 0), 0);
                const designTotal = state.designCosts[state.design] || 0;
                const total = state.baseCost + funcTotal + designTotal;

                document.getElementById('costBase').textContent = state.baseCost.toLocaleString() + ' ₽';
                document.getElementById('funcCount').textContent = state.functions.length;
                document.getElementById('costFuncs').textContent = funcTotal.toLocaleString() + ' ₽';
                document.getElementById('costDesign').textContent = designTotal.toLocaleString() + ' ₽';
                document.getElementById('costTotal').textContent = total.toLocaleString() + ' ₽';

                // deadline estimate
                const days = Math.max(3, 5 + Math.floor(state.functions.length / 3));
                document.getElementById('costDeadline').textContent = 'от ' + days + ' дней';
            }

            // ---------- SUBMIT REQUEST ----------
            document.getElementById('submitRequestBtn').addEventListener('click', function() {
                const desc = document.getElementById('projectDesc').value.trim() || 'Без описания';
                const total = document.getElementById('costTotal').textContent;

                // build payload
                const payload = {
                    type: state.projectType,
                    functions: state.functions,
                    design: state.design,
                    description: desc,
                    cost: total,
                    user: state.user,
                    timestamp: new Date().toISOString(),
                };

                // In real app: send to API
                // For demo: show success
                console.log('📨 Заявка отправлена:', payload);

                // Show success with Telegram-like haptic
                if (window.Telegram?.WebApp?.HapticFeedback) {
                    try {
                        window.Telegram.WebApp.HapticFeedback.notificationOccurred('success');
                    } catch (e) {}
                }

                showToast('✅ Заявка отправлена! Мы свяжемся с вами в ближайшее время.', 4000);

                // Reset form (optional)
                // We keep state for demo
            });

            // ---------- PROFILE ----------
            function updateProfile() {
                const u = state.user;
                document.getElementById('profileName').textContent = u.name;
                document.getElementById('profileUsername').textContent = u.username;
                document.getElementById('profileId').textContent = 'ID: ' + u.id;
                document.getElementById('profileDate').textContent = u.registered;
                document.getElementById('profileRequests').textContent = u.requests;
                document.getElementById('profileAvatar').textContent = u.name.charAt(0).toUpperCase();
            }

            // ---------- LOGOUT ----------
            document.getElementById('logoutBtn').addEventListener('click', () => {
                if (window.Telegram?.WebApp?.HapticFeedback) {
                    try { window.Telegram.WebApp.HapticFeedback.impactOccurred('light'); } catch (e) {}
                }
                showToast('👋 До встречи!');
                showPage('home');
            });

            // ---------- TELEGRAM SDK INTEGRATION (simulated) ----------
            // If running inside Telegram, the SDK will be available.
            // We simulate basic functionality for web preview.

            // Check if Telegram WebApp is available
            if (window.Telegram?.WebApp) {
                try {
                    const tg = window.Telegram.WebApp;
                    tg.ready();
                    tg.expand();
                    // Use theme params
                    const theme = tg.themeParams || {};
                    if (theme.bg_color) {
                        document.body.style.background = theme.bg_color;
                    }
                    // User data
                    if (tg.initDataUnsafe?.user) {
                        const user = tg.initDataUnsafe.user;
                        state.user.name = user.first_name || user.username || 'Пользователь';
                        state.user.username = user.username ? '@' + user.username : '@user';
                        state.user.id = user.id || '—';
                    }
                    // Haptic feedback
                    tg.HapticFeedback = tg.HapticFeedback || {
                        impactOccurred: () => {},
                        notificationOccurred: () => {},
                        selectionChanged: () => {},
                    };
                    // Main button
                    tg.MainButton = tg.MainButton || {
                        show: () => {},
                        hide: () => {},
                        setText: () => {},
                        onClick: () => {},
                    };
                    // Back button
                    tg.BackButton = tg.BackButton || {
                        show: () => {},
                        hide: () => {},
                        onClick: () => {},
                    };
                    console.log('✅ Telegram SDK ready');
                } catch (e) {
                    console.log('Telegram SDK init warning:', e);
                }
            } else {
                // Simulate Telegram SDK for web preview
                window.Telegram = window.Telegram || {};
                window.Telegram.WebApp = {
                    ready: () => console.log('WebApp ready (sim)'),
                    expand: () => console.log('Expand (sim)'),
                    themeParams: { bg_color: '#0a0a0f', text_color: '#f0f0ff' },
                    initDataUnsafe: { user: { id: 987654, first_name: 'Демо', username: 'demo_user' } },
                    HapticFeedback: {
                        impactOccurred: () => console.log('Haptic impact'),
                        notificationOccurred: () => console.log('Haptic notification'),
                        selectionChanged: () => console.log('Haptic selection'),
                    },
                    MainButton: { show: () => {}, hide: () => {}, setText: () => {}, onClick: () => {} },
                    BackButton: { show: () => {}, hide: () => {}, onClick: () => {} },
                };
                console.log('ℹ️ Telegram SDK simulated for web preview');
                // Update profile with demo user
                state.user.name = 'Демо';
                state.user.username = '@demo_user';
                state.user.id = '987654';
                state.user.registered = '2026-07-22';
                state.user.requests = 2;
            }

            // ---------- INIT ----------
            showPage('home');
            updateProfile();
            renderStep(0);

            // ---------- KEYBOARD SHORTCUT (dev) ----------
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    if (state.page !== 'home') showPage('home');
                }
            });

            console.log('🚀 NOVA Mini App loaded');
            console.log('📦 State:', state);

        })();
    </script>

