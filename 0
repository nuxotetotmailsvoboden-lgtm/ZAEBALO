            <button class="nav-item" data-page="constructor"><span class="nav-icon">⚙️</span><span>Конструктор</span></button>
            <button class="nav-item" data-page="portfolio"><span class="nav-icon">📁</span><span>Портфолио</span></button>
            <button class="nav-item" data-page="profile"><span class="nav-icon">👤</span><span>Профиль</span></button>
