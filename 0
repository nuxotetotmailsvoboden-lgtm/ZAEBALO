                <!-- STEP 4: Cost -->
                <div id="step-3" class="step-panel" style="display:none;">
                    <h3 class="text-lg font-semibold mb-1">Шаг 4. Стоимость</h3>
                    <p class="text-sm text-purple-200/50 mb-4">Итоговая цена вашего проекта</p>

                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between py-1 border-b border-white/5"><span>Базовый бот</span><span class="font-medium" id="costBase">40 000 ₽</span></div>
                        <div class="flex justify-between py-1 border-b border-white/5"><span>Функции (<span id="funcCount">0</span>)</span><span class="font-medium" id="costFuncs">0 ₽</span></div>
                        <div class="flex justify-between py-1 border-b border-white/5"><span>Дизайн</span><span class="font-medium" id="costDesign">0 ₽</span></div>
                        <div class="flex justify-between py-1 border-b border-white/5 text-purple-300"><span>Срок</span><span class="font-medium" id="costDeadline">от 5 дней</span></div>
                        <div class="flex justify-between pt-3 text-lg font-bold"><span>Итого</span><span class="neon-text" id="costTotal">40 000 ₽</span></div>
                    </div>

                    <div class="mt-5">
                        <label class="text-sm text-purple-200/60 block mb-1">Описание проекта</label>
                        <textarea id="projectDesc" rows="3" class="w-full bg-white/5 border border-white/10 rounded-xl p-3 text-sm text-white placeholder:text-purple-200/30 focus:outline-none focus:border-purple-500/50 transition resize-none" placeholder="Расскажите о вашей идее..."></textarea>
